# ── LLM ────────────────────────────────────────────────────────────────────────
LLM_BINDING=openai
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-oss-20b
LLM_API_KEY=your-api-key

# ── Embedding ──────────────────────────────────────────────────────────────────
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=perplexity/pplx-embed-v1-0.6b
EMBEDDING_DIM=1024
EMBEDDING_API_KEY=your-api-key
EMBEDDING_API_BASE=https://openrouter.ai/api/v1

# ── Ragas Evaluation Overrides ─────────────────────────────────────────────────
# Optional: override the LLM used for Ragas metric scoring (leave blank to use LLM_MODEL).
RAGAS_LLM_MODEL=openai/gpt-4o-mini

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=gripl-rag-2026

# ── LightRAG Paths ────────────────────────────────────────────────────────────
RAG_WORKING_DIR=./rag_working_dir
EXTRACTED_DATA_DIR=./data/extracted
