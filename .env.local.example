OPENAI_API_KEY=sk-xxx
OPEN_ROUTER_API_KEY=or-xxx

# ── gripl-rag / LightRAG settings ──────────────────────────────────────────
LLM_BINDING=openai
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash
LLM_API_KEY=or-xxx

EMBEDDING_BINDING=openai
EMBEDDING_MODEL=openai/text-embedding-3-large
EMBEDDING_DIM=3072
EMBEDDING_API_KEY=or-xxx
EMBEDDING_API_BASE=https://openrouter.ai/api/v1

# ── Rerank ────────────────────────────────────────────────────
# "local" uses BAAI/bge-reranker-v2-m3 via sentence-transformers (no API key needed)
# "cohere" uses Cohere via OpenRouter (requires RERANK_API_KEY)
# "none" disables reranking (default)
RERANK_BINDING=none
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_API_KEY=or-xxx
# RERANK_API_BASE=https://openrouter.ai/api/v1/rerank
# RERANK_TOP_N=10

RAG_WORKING_DIR=./rag_working_dir
EXTRACTED_DATA_DIR=./data/extracted

# spring / backend
SPRING_PROFILES_ACTIVE=dev

# postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gripldb

# pgadmin
PGADMIN_DEFAULT_EMAIL=admin@local
PGADMIN_DEFAULT_PASSWORD=admin

# local ports
FRONTEND_PORT=3000
BACKEND_PORT=8080
RAG_PORT=8081
POSTGRES_PORT=5432
PGADMIN_PORT=5050

# neo4j (used by gripl-rag)
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=gripl-rag-2026

# Ragas evaluation overrides
RAGAS_LLM_MODEL=openai/gpt-4o-mini

# optional traefik
TRAEFIK_NETWORK=web
TRAEFIK_ACME_EMAIL=you@example.com
